datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String      @id @default(uuid())
  firstName    String
  lastName     String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
}

model Department {
  id    String @id @default(uuid())
  name  String
  users User[]
  assets Asset[]
}

model AssetCategory {
  id     String  @id @default(uuid())
  name   String
  assets Asset[]
}

model Asset {
  id           String        @id @default(uuid())
  name         String
  categoryId   String
  category     AssetCategory @relation(fields: [categoryId], references: [id])
  departmentId String?
  department   Department?   @relation(fields: [departmentId], references: [id])
}